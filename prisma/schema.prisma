generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductSize {
  PP
  P
  M
  G
  GG
  UNICO
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String

  price       Int

  featured    Boolean  @default(false)
  bestSeller  Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId   String
  collectionId String?

  category    Category   @relation(fields: [categoryId], references: [id])
  collection  Collection? @relation(fields: [collectionId], references: [id])

  images ProductImage[]
  sizes  ProductSizeItem[]
  colors ProductColor[]
  orderItems OrderItem[]
}

model Category {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String

  products Product[]
}

model Collection {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  tagline     String
  image       String
  featured    Boolean @default(false)

  products Product[]
}

model ProductImage {
  id        String @id @default(cuid())
  url       String
  order     Int @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSizeItem {
  id        String @id @default(cuid())

  size ProductSize

  productId String
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductColor {
  id        String @id @default(cuid())

  color String

  productId String
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SiteConfig {

  id String @id @default(cuid())

  name String
  tagline String

  heroTitle String
  heroSubtitle String
  heroCtaLabel String
  heroCtaHref String

  aboutTitle String
  artisanName String

  contactWhatsapp String
  contactEmail String
  contactCity String

  measuresIntro String

  aboutParagraphs AboutParagraph[]
  measureRows     MeasureRow[]
}

model AboutParagraph {

  id String @id @default(cuid())

  text String

  order Int

  siteConfigId String

  siteConfig SiteConfig @relation(fields:[siteConfigId], references:[id], onDelete: Cascade)
}

model MeasureRow {

  id String @id @default(cuid())

  size String

  bust String

  waist String

  hip String

  order Int

  siteConfigId String

  siteConfig SiteConfig @relation(fields:[siteConfigId], references:[id], onDelete: Cascade)
}

// ---------- Área administrativa ----------

enum UserRole {
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELED
}

model Order {
  id          String      @id @default(cuid())
  orderNumber Int         @unique @default(autoincrement())
  status      OrderStatus @default(PENDING)

  customerName  String
  customerPhone String
  customerEmail String?

  addressStreet       String
  addressNumber       String
  addressComplement   String?
  addressNeighborhood String
  addressCity         String
  addressState        String
  addressZipCode      String

  notes      String?
  subtotalPrice         Int
  shippingPrice         Float    @default(0)
  shippingCarrier       String?
  shippingEstimatedDays Int?
  totalPrice            Float

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // snapshot dos dados do produto no momento do pedido (produto pode mudar de preço/ser removido depois)
  productName String
  productSlug String
  unitPrice   Int
  size        String?
  color       String?
  quantity    Int
}

enum QuoteStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  CLOSED
}

model QuoteRequest {
  id String @id @default(cuid())

  name        String
  phone       String
  email       String?
  description String

  status     QuoteStatus @default(NEW)
  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ContactStatus {
  NEW
  READ
  ANSWERED
}

model ContactMessage {
  id String @id @default(cuid())

  name    String
  email   String
  phone   String?
  message String

  status ContactStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}