# PORT=3001

# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maya_croche"

# JWT_SECRET=supersecret

# JWT_EXPIRES_IN=1d

# # Origens permitidas no CORS (separadas por vírgula). Frontend Next.js em 3000; API em 3001.
# CORS_ORIGIN=http://localhost:3000

# # Credenciais do admin criado pelo prisma/seed.ts (só roda se ADMIN_SEED_PASSWORD estiver definida)
# ADMIN_SEED_NAME=Admin
# ADMIN_SEED_EMAIL=admin@mayacroche.com.br
# ADMIN_SEED_PASSWORD=troque-esta-senha

# # Credenciais da conta Cloudinary usada pelo POST /admin/uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# SuperFrete — cotação de frete
# Sandbox: https://sandbox.superfrete.com (token gerado em sandbox.superfrete.com/#/integrations)
# Produção: https://api.superfrete.com (token gerado em web.superfrete.com/#/integrations)
SUPERFRETE_TOKEN=
SUPERFRETE_API_URL=https://api.superfrete.com
SUPERFRETE_SERVICES=1,2,17
SHIPPING_ORIGIN_ZIP=66055000

# SUPERFRETE_TOKEN