# PORT=3000

# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maya_croche"

# JWT_SECRET=supersecret

# JWT_EXPIRES_IN=1d

# # Origens permitidas no CORS (separadas por vírgula). O frontend Next.js roda em 3001
# # por padrão pra não colidir com a porta 3000 da API.
# CORS_ORIGIN=http://localhost:3001

# # Credenciais do admin criado pelo prisma/seed.ts (só roda se ADMIN_SEED_PASSWORD estiver definida)
# ADMIN_SEED_NAME=Admin
# ADMIN_SEED_EMAIL=admin@mayacroche.com.br
# ADMIN_SEED_PASSWORD=troque-esta-senha

# # Credenciais da conta Cloudinary usada pelo POST /admin/uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=